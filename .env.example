# Copiar a variables de entorno del proyecto en Vercel (Project Settings > Environment Variables).
# Nunca poner valores reales en este archivo ni commitearlos.

# API key de Anthropic para el endpoint /api/agente-conversion (server-side only).
ANTHROPIC_API_KEY=

# Token compartido simple para autorizar escrituras en /api/storage/:key.
# Genera uno random, ej: openssl rand -hex 20
STORAGE_WRITE_TOKEN=

# Inyectada automáticamente al conectar Vercel Postgres (Storage > Postgres) al proyecto.
# No hace falta llenarla a mano.
POSTGRES_URL=
