{
  "rewrites": [
    { "source": "/agentes", "destination": "/agentes.html" }
  ],
  "headers": [
    {
      "source": "/(agentes|agentes.html|agente-conversion-ventas.html|selector-historias-contenido.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
