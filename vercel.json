{
  "rewrites": [
    { "source": "/",                      "destination": "/consultor.html" },
    { "source": "/adn",                   "destination": "/ADN.html?cliente=jefeshub" },
    { "source": "/consultor-contenido",   "destination": "/agente-contenido-v2.html?cliente=jefeshub" },
    { "source": "/consultor-whatsapp",    "destination": "/agente-conversion-ventas.html?cliente=jefeshub" },
    { "source": "/consultor-radar",       "destination": "/consultor-radar-mercado.html?cliente=jefeshub" },
    { "source": "/consultor-evergreen",   "destination": "/consultor-evergreen.html" },
    { "source": "/agentes",               "destination": "/agentes.html" },

    { "source": "/rancho-seco",                      "destination": "/rancho-seco-central-agentes.html" },
    { "source": "/rancho-seco/adn",                  "destination": "/ADN.html?cliente=rancho-seco" },
    { "source": "/rancho-seco/consultor-contenido",  "destination": "/agente-contenido-v2.html?cliente=rancho-seco" },
    { "source": "/rancho-seco/consultor-whatsapp",   "destination": "/agente-conversion-ventas.html?cliente=rancho-seco" },
    { "source": "/rancho-seco/consultor-radar",      "destination": "/consultor-radar-mercado.html?cliente=rancho-seco" },
    { "source": "/rancho-seco/consultor-evergreen",   "destination": "/consultor-evergreen.html" },
    { "source": "/rancho-seco/conversion-ventas",    "destination": "/agente-conversion-ventas-rancho-seco.html" },

    { "source": "/rim",                      "destination": "/rim-central-agentes.html" },
    { "source": "/rim/adn",                  "destination": "/ADN.html?cliente=rim" },
    { "source": "/rim/consultor-contenido",  "destination": "/agente-contenido-v2.html?cliente=rim" },
    { "source": "/rim/consultor-whatsapp",   "destination": "/agente-conversion-ventas.html?cliente=rim" },
    { "source": "/rim/consultor-radar",      "destination": "/consultor-radar-mercado.html?cliente=rim" },
    { "source": "/rim/consultor-evergreen",  "destination": "/consultor-evergreen.html" },

    { "source": "/jefeshub/consultor-radar", "destination": "/consultor-radar-mercado.html?cliente=jefeshub" }
  ],
  "headers": [
    {
      "source": "/(|consultor.html|adn|ADN.html|consultor-contenido|agente-contenido-v2.html|consultor-whatsapp|agente-conversion-ventas.html|consultor-radar|consultor-evergreen|consultor-evergreen.html|agentes|agentes.html|selector-historias-contenido.html|rancho-seco|rancho-seco-central-agentes.html|agente-conversion-ventas-rancho-seco.html|consultor-radar-mercado.html|rim|rim-central-agentes.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/rancho-seco/(adn|consultor-contenido|consultor-whatsapp|consultor-radar|consultor-evergreen|conversion-ventas)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/rim/(adn|consultor-contenido|consultor-whatsapp|consultor-radar|consultor-evergreen)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/jefeshub/consultor-radar",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/agente-conversion.js": {
      "includeFiles": "prompts/**"
    },
    "api/consultor-radar.js": {
      "includeFiles": "prompts/**"
    },
    "api/consultor-evergreen.js": {
      "includeFiles": "prompts/**"
    },
    "api/consultor-evergreen-builder.js": {
      "includeFiles": "prompts/**"
    },
    "api/generar-ideas-evergreen.js": {
      "includeFiles": "prompts/**"
    }
  }
}
