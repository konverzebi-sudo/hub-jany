{
  "rewrites": [
    { "source": "/agentes", "destination": "/agentes.html" },
    { "source": "/rancho-seco", "destination": "/rancho-seco-central-agentes.html" },
    { "source": "/rancho-seco/conversion-ventas", "destination": "/agente-conversion-ventas-rancho-seco.html" },
    { "source": "/rancho-seco/consultor-radar", "destination": "/consultor-radar-mercado.html" }
  ],
  "headers": [
    {
      "source": "/(agentes|agentes.html|agente-conversion-ventas.html|selector-historias-contenido.html|ADN.html|rancho-seco|rancho-seco-central-agentes.html|agente-conversion-ventas-rancho-seco.html|consultor-radar-mercado.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/rancho-seco/(conversion-ventas|consultor-radar)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/agente-conversion.js": {
      "includeFiles": "prompts/**"
    },
    "api/consultor-radar.js": {
      "includeFiles": "prompts/**"
    }
  }
}
