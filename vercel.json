{
  "rewrites": [
    { "source": "/",                      "destination": "/consultor.html" },
    { "source": "/adn",                   "destination": "/ADN.html" },
    { "source": "/consultor-contenido",   "destination": "/agente-contenido-v2.html" },
    { "source": "/consultor-whatsapp",    "destination": "/agente-conversion-ventas.html" },
    { "source": "/consultor-radar",       "destination": "/consultor-radar-mercado.html?cliente=jefeshub" },
    { "source": "/agentes",               "destination": "/agentes.html" },
    { "source": "/rancho-seco",           "destination": "/rancho-seco-central-agentes.html" },
    { "source": "/rancho-seco/conversion-ventas", "destination": "/agente-conversion-ventas-rancho-seco.html" },
    { "source": "/rancho-seco/consultor-radar",   "destination": "/consultor-radar-mercado.html" },
    { "source": "/jefeshub/consultor-radar",      "destination": "/consultor-radar-mercado.html?cliente=jefeshub" }
  ],
  "headers": [
    {
      "source": "/(|consultor.html|adn|ADN.html|consultor-contenido|agente-contenido-v2.html|consultor-whatsapp|agente-conversion-ventas.html|consultor-radar|agentes|agentes.html|selector-historias-contenido.html|rancho-seco|rancho-seco-central-agentes.html|agente-conversion-ventas-rancho-seco.html|consultor-radar-mercado.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/rancho-seco/(conversion-ventas|consultor-radar)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/jefeshub/consultor-radar",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/agente-conversion.js": {
      "includeFiles": "prompts/**"
    },
    "api/consultor-radar.js": {
      "includeFiles": "prompts/**"
    }
  }
}
